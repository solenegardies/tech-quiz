{
  "name": "@tech-quiz/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./enums": {
      "types": "./src/enums/index.ts",
      "default": "./dist/enums/index.js"
    },
    "./toolbox": {
      "types": "./src/toolbox/index.ts",
      "default": "./dist/toolbox/index.js"
    },
    "./utils": {
      "types": "./src/utils/email.ts",
      "default": "./dist/utils/email.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
